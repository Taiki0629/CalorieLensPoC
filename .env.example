# このファイルはキー名のテンプレートです。実値は .env に記入し、.env は絶対にコミットしないこと。
# 使い方: `cp .env.example .env` してから値を埋める。

# === OpenAI 本家 ===
OPENAI_API_KEY=sk-...

# === ai& Inference（OpenAI互換エンドポイント） ===
# base_url と APIキー。実際のエンドポイントは公式情報で確認すること（推測禁止）。
AIAND_API_KEY=sk-aiand-...
AIAND_BASE_URL=https://api.aiand.example/v1
