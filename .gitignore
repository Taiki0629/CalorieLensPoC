# === 秘密情報（絶対にコミットしない） ===
.env
.env.local
.env.*.local
*.key
*.pem

# === Python / uv ===
__pycache__/
*.py[cod]
.venv/
venv/
.uv/
*.egg-info/
.ruff_cache/
.pytest_cache/
.mypy_cache/

# === 作業領域・一時ファイル ===
99_scratch/
*.tmp
*.log
.DS_Store
# Windows(WSL) のダウンロード印 (Alternate Data Stream) — 実体ではないので除外
*:Zone.Identifier

# === 実験の生成物のうちコミットしないもの ===
# 生の大容量レスポンスやキャッシュ（必要に応じて調整）
30_development/**/cache/
30_development/**/.cache/
# デモ/使い捨ての合成生成物（seed から再生成可。図のみ 50_output/figures/demo に残す）
30_development/data/logs/demo/
30_development/data/logs/_dryrun/
30_development/data/results/demo/
30_development/data/labels/demo_labels.csv

# === エディタ ===
.idea/
.vscode/

